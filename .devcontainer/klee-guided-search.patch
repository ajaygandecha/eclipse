+
+using namespace klee;
+
+GuidedSearcher::GuidedSearcher(std::unordered_set<std::string> riskyFunctions)
+    : riskyFunctions(std::move(riskyFunctions)) {}
+
+bool GuidedSearcher::isRiskyState(const ExecutionState &state) const {
+  auto *inst = state.pc->inst;
+  if (!inst)
+    return false;
+
+  auto *function = inst->getFunction();
+  if (!function)
+    return false;
+
+  return riskyFunctions.find(function->getName().str()) != riskyFunctions.end();
+}
+
+ExecutionState &GuidedSearcher::selectState() {
+  assert(!states.empty() && "GuidedSearcher has no states");
+
+  const std::size_t startIndex = nextIndex % states.size();
+
+  for (std::size_t offset = 0; offset < states.size(); ++offset) {
+    const std::size_t index = (startIndex + offset) % states.size();
+    if (isRiskyState(*states[index])) {
+      nextIndex = (index + 1) % states.size();
+      return *states[index];
+    }
+  }
+
+  nextIndex = (startIndex + 1) % states.size();
+  return *states[startIndex];
+}
+
+void GuidedSearcher::update(ExecutionState *current,
+                            const std::vector<ExecutionState *> &addedStates,
+                            const std::vector<ExecutionState *> &removedStates) {
+  states.insert(states.end(), addedStates.begin(), addedStates.end());
+
+  for (const auto *state : removedStates) {
+    auto it = std::find(states.begin(), states.end(), state);
+    assert(it != states.end() && "invalid state removed");
+    const std::size_t removedIndex = std::distance(states.begin(), it);
+    states.erase(it);
+
+    if (nextIndex > removedIndex && nextIndex != 0)
+      --nextIndex;
+  }
+
+  if (states.empty()) {
+    nextIndex = 0;
+  } else if (nextIndex >= states.size()) {
+    nextIndex = 0;
+  }
+}
+
+bool GuidedSearcher::empty() { return states.empty(); }
+
+void GuidedSearcher::printName(llvm::raw_ostream &os) {
+  os << "GuidedSearcher\n";
+}
