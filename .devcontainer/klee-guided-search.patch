+
+std::string resolveGuidancePath(const std::string &defaultGuidancePath) {
+  if (const char *path = std::getenv("ECLIPSE_GUIDANCE_FILE")) {
+    if (*path)
+      return std::string(path);
+  }
+  return defaultGuidancePath;
+}
+
+std::unordered_set<std::string> loadGuidedFunctions(const std::string &guidancePath) {
+  auto guidanceFile = MemoryBuffer::getFile(guidancePath);
+  if (!guidanceFile) {
+    klee_error("unable to read guidance file '%s': %s", guidancePath.c_str(),
+               guidanceFile.getError().message().c_str());
+  }
+
+  auto parsedJSON = json::parse((*guidanceFile)->getBuffer());
+  if (!parsedJSON) {
+    klee_error("unable to parse guidance file '%s': %s", guidancePath.c_str(),
+               toString(parsedJSON.takeError()).c_str());
+  }
+
+  auto *guidanceObject = parsedJSON->getAsObject();
+  if (!guidanceObject)
+    klee_error("guidance file '%s' must contain a top-level JSON object",
+               guidancePath.c_str());
+
+  auto *riskyFunctions = guidanceObject->getArray("risky_functions");
+  if (!riskyFunctions)
+    klee_error("guidance file '%s' is missing a 'risky_functions' array",
+               guidancePath.c_str());
+
+  std::unordered_set<std::string> loadedFunctions;
+  for (const auto &entry : *riskyFunctions) {
+    auto functionName = entry.getAsString();
+    if (!functionName) {
+      klee_error("guidance file '%s' contains a non-string risky function entry",
+                 guidancePath.c_str());
+    }
+    loadedFunctions.insert(functionName->str());
+  }
+
+  return loadedFunctions;
+}
